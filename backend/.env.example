# Server config
PORT=5000
NODE_ENV=development

# Database config
MONGODB_URI=mongodb://localhost:27017/jyotishlink

# JWT Secrets
JWT_ACCESS_SECRET=your_jwt_access_token_secret_key_123456
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_key_789012
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# INDIA SMS HUB config
INDIA_SMS_HUB_API_KEY=hdw64KJTekumwJSJdHdapQ
INDIA_SMS_HUB_SENDER_ID=
INDIA_SMS_HUB_TEMPLATE_ID=your_template_id
INDIA_SMS_HUB_BASE_URL=https://api.indiasmshub.com/api/v2/sendsms

# Cloudinary config
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AWS Config (Optional alternate file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=your_s3_bucket

# Payment Config (Razorpay or similar)
PAYMENT_GATEWAY_KEY_ID=your_payment_gateway_key
PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret

# Redis config (for caching, optional)
REDIS_URL=redis://localhost:6379

# SMTP configuration for emails
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@jyotishlink.com

# Firebase Admin SDK configuration (Optional notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key
